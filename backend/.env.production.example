APP_NAME=CreatorLab API
APP_ENV=production
CORS_ORIGINS=["https://creatorlab.example.com"]
STORAGE_ROOT=/app/storage
DATABASE_PATH=/app/storage/creatorlab.db
STORAGE_BACKEND=local
MAX_UPLOAD_MB=25
MAX_BATCH_UPLOAD_MB=80
MAX_REQUEST_MB=90
TEMP_FILE_TTL_HOURS=24
OUTPUT_FILE_TTL_HOURS=168
WORKER_THREADS=4
WORKER_QUEUE_SIZE=256
JOB_MAX_RETRIES=2
CLEANUP_INTERVAL_SECONDS=300
UPLOAD_RATE_LIMIT_PER_MINUTE=20
REALESRGAN_MODEL_NAME=RealESRGAN_x4plus
REALESRGAN_WEIGHTS_URL=https://github.com/xinntao/Real-ESRGAN/releases/download/v0.1.0/RealESRGAN_x4plus.pth
LIGHTWEIGHT_AI_MODEL_NAME=RealESRGAN_x2plus
LIGHTWEIGHT_AI_WEIGHTS_URL=https://github.com/xinntao/Real-ESRGAN/releases/download/v0.2.1/RealESRGAN_x2plus.pth
ENABLE_HEAVY_AI=true
UPSCALE_MAX_INPUT_PIXELS=2800000
UPSCALE_MAX_EDGE=2200
UPSCALE_TIMEOUT_SECONDS=25
MAX_CONCURRENT_AI_JOBS=1
REMBG_MODEL_NAME=u2net
LOG_LEVEL=INFO
LOG_JSON=true
AUTH_SECRET_KEY=replace-with-a-long-random-secret
SESSION_COOKIE_NAME=creatorlab_session
VISITOR_COOKIE_NAME=creatorlab_visitor
SESSION_TTL_DAYS=14
VISITOR_TTL_DAYS=180
COOKIE_DOMAIN=.example.com
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=lax
ANONYMOUS_MONTHLY_JOBS=50
REQUIRE_AUTH_FOR_JOBS=true
REQUIRE_EMAIL_VERIFICATION=true
BLOCK_UNVERIFIED_USERS_FROM_JOBS=true
APP_PUBLIC_URL=https://creatorlab.example.com
API_PUBLIC_URL=https://creatorlab.example.com
MAIL_BACKEND=smtp
MAIL_FROM_EMAIL=no-reply@creatorlab.example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=apikey
SMTP_PASSWORD=replace-with-your-smtp-password
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT_SECONDS=20
EMAIL_VERIFICATION_TTL_HOURS=24
PASSWORD_RESET_TTL_MINUTES=60
